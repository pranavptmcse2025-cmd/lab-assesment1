# DEMONSTRATION & DRIVER CODE
# ==========================================
if __name__ == "__main__":
    # Number of vertices: 0, 1, 2, 3, 4
    V = 5

    # Graph represented as an Edge List (u, v, weight)
    edge_list = [
        (0, 1, 2),
        (0, 3, 6),
        (1, 2, 3),
        (1, 3, 8),
        (1, 4, 5),
        (2, 4, 7),
        (3, 4, 9),
    ]

    # Convert Edge List to Adjacency List for Prim's Algorithm
    adj_list = {i: [] for i in range(V)}
    for u, v, w in edge_list:
        adj_list[u].append((v, w))
        adj_list[v].append((u, w))

    print("=" * 60)
    print("         MINIMUM SPANNING TREE (MST) EXECUTION        ")
    print("=" * 60)

    # 1. Run Kruskal's Algorithm
    kruskal_edges, kruskal_weight = kruskal_mst(V, edge_list)
    print("\n--- Kruskal's Algorithm ---")
    print("Selected Edges (u, v, weight):")
    for u, v, w in kruskal_edges:
        print(f"  {u} -- {v} == {w}")
    print(f"Total MST Weight: {kruskal_weight}")

    # 2. Run Prim's Algorithm
    prim_edges, prim_weight = prim_mst(V, adj_list, start_vertex=0)
    print("\n--- Prim's Algorithm ---")
    print("Selected Edges (u, v, weight):")
    for u, v, w in prim_edges:
        print(f"  {u} -- {v} == {w}")
    print(f"Total MST Weight: {prim_weight}")

    print("\n" + "=" * 60)
